local function tween(obj, props, t, style, dir)
    TweenService:Create(
        obj,
        TweenInfo.new(t or 0.2, style or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out),
        props
    ):Play()
end

local function pulse(btn, normalColor, hoverColor)
    btn.MouseEnter:Connect(function()
        tween(btn, { BackgroundColor3 = hoverColor }, 0.13)
    end)
    btn.MouseLeave:Connect(function()
        tween(btn, { BackgroundColor3 = normalColor }, 0.13)
    end)
end


-- ─────────────────────────────────────────────
-- JIGGLE ON CLICK
-- ─────────────────────────────────────────────
local function jiggle(btn)
    btn.MouseButton1Click:Connect(function()
        tween(btn, { Rotation =  4 }, 0.06, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        task.delay(0.06, function()
            tween(btn, { Rotation = -4 }, 0.06, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
            task.delay(0.06, function()
                tween(btn, { Rotation =  2 }, 0.05, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
                task.delay(0.05, function()
                    tween(btn, { Rotation =  0 }, 0.05, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
                end)
            end)
        end)
    end)
end

