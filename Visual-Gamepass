-- Helper Stuff ykyk

local function formatNumber(num)

    local formatted = tostring(num)

    local k

    while true do

        formatted, k = string.gsub(formatted, "^(-?%d+)(%d%d%d)", '%1,%2')

        if k == 0 then break end

    end

    return formatted

end

-- funcions

local function formatNumberShort(num)

    local abs = math.abs(num)

    local sign = num < 0 and "-" or ""

    

    if abs >= 1e9 then

        -- Billions

        local billions = abs / 1e9

        if billions >= 10 then

            return sign .. string.format("%.0f", billions) .. "B"

        else

            return sign .. string.format("%.1f", billions) .. "B"

        end

    elseif abs >= 1e6 then

        -- Millions

        local millions = abs / 1e6

        if millions >= 10 then

            return sign .. string.format("%.0f", millions) .. "M"

        else

            return sign .. string.format("%.1f", millions) .. "M"

        end

    elseif abs >= 1e3 then

        -- Thousands

        local thousands = abs / 1e3

        if thousands >= 10 then

            return sign .. string.format("%.0f", thousands) .. "K"

        else

            return sign .. string.format("%.1f", thousands) .. "K"

        end

    else

        -- Under 1000, show full number

        return sign .. string.format("%.0f", abs)

    end

end

local function parseNumber(str)

    local cleanedStr = string.gsub(str, ",", "")

    return tonumber(cleanedStr)

end

local function getUsernameFromBoothItem(itemFrame)

    local success, result = pcall(function()

        for _, child in ipairs(itemFrame:GetDescendants()) do

            if child:IsA("TextLabel") or child:IsA("TextButton") then

                local text = child.Text

                if text and string.find(text, "@") then

                    local usernameMatch = string.match(text, "@([%w_]+)")

                    if usernameMatch then return usernameMatch end

                end

            end

        end

        return nil

    end)

    if success and result then return result end

    return nil

end

-- Extract shit

local function getButtonId(obj)

    for name, val in pairs(obj:GetAttributes()) do

        if (string.find(name:lower(), "id") or string.find(name:lower(), "asset")) and type(val) == "number" then

            return val

        end

    end

    

    for _, child in ipairs(obj:GetChildren()) do

        if (string.find(child.Name:lower(), "id") or string.find(child.Name:lower(), "asset")) and (child:IsA("NumberValue") or child:IsA("IntValue")) then

            return child.Value

        end

    end

    

    if tonumber(obj.Name) then

        return tonumber(obj.Name)

    end

    local id = string.match(obj.Name, "Item(%d+)")

    if id then

        return tonumber(id)

    end

    if obj.Parent then

        local pId = string.match(obj.Parent.Name, "Item(%d+)")

        if pId then

            return tonumber(pId)

        end

    end

    

    return nil

end

-- the fetching stuff or wtv

local function getProductInfo(gamepassId)

    local success, info = pcall(function()

        return MarketplaceService:GetProductInfo(gamepassId, Enum.InfoType.GamePass)

    end)

    

    if success and info then

        return {

            Name = info.Name or "Unknown Product",

            IconImageAssetId = gamepassId,

            PriceInRobux = info.PriceInRobux or 0,

            AssetId = gamepassId

        }

    else

        return {

            Name = "Unknown Product",

            IconImageAssetId = gamepassId,

            PriceInRobux = 0,

            AssetId = gamepassId

        }

    end

end

-- Update Donated Value (Leaderboard)

local function updateDonatedValue(amountToAdd)

    local customCoreGui = playerGui:FindFirstChild("CustomCoreGui")

    if customCoreGui then

        local playerlist = customCoreGui:FindFirstChild("Playerlist")

        if playerlist then

            local scrollingFrame = playerlist:FindFirstChild("ScrollingFrame")

            if scrollingFrame then

                local userId = tostring(player.UserId)

                local userFrame = scrollingFrame:FindFirstChild("User" .. userId)

                if userFrame then

                    local stats = userFrame:FindFirstChild("Stats")

                    if stats then

                        local donated = stats:FindFirstChild("Donated")

                        if donated then

                            local currentDonatedText = donated.Text

                            local cleanedText = string.gsub(currentDonatedText, "[^%d,]", "")

                            local currentDonated = parseNumber(cleanedText) or 0

                            local newDonated = currentDonated + amountToAdd

                            

