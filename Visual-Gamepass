-- DRAG LOGIC
-- ─────────────────────────────────────────────
local dragInput, dragStart, startPos

settingsFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
    or input.UserInputType == Enum.UserInputType.Touch then
        dragStart = input.Position
        startPos  = settingsFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragStart = nil
            end
        end)
    end
end)

settingsFrame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement
    or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragStart then
        local delta = input.Position - dragStart
        settingsFrame.Position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
    end
end)

-- ─────────────────────────────────────────────
-- BUBBLE OPEN / CLOSE
-- ─────────────────────────────────────────────
local function openHub()
    if isAnimating then return end
    isAnimating   = true
    isOpen        = true
    content.Visible = true

    settingsFrame.Visible = true
    settingsFrame.Size    = SEED_SIZE

    -- pop out like a bubble  (Back Out = slight overshoot)
    TweenService:Create(
        settingsFrame,
        TweenInfo.new(0.42, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
        { Size = FULL_SIZE }
    ):Play()

    task.delay(0.42, function() isAnimating = false end)
end

local function closeHub()
    if isAnimating then return end
    isAnimating = true
    isOpen      = false
    content.Visible = false

    -- shrink inward  (Back In = pull back before collapsing)
    local t = TweenService:Create(
        settingsFrame,
        TweenInfo.new(0.28, Enum.EasingStyle.Back, Enum.EasingDirection.In),
        { Size = SEED_SIZE }
    )
    t:Play()
    t.Completed:Connect(function()
        settingsFrame.Visible = false
        settingsFrame.Size    = FULL_SIZE  -- reset for next open
        isAnimating           = false
    end)
end

toggleBtn.MouseButton1Click:Connect(function()
    if isOpen then closeHub() else openHub() end
end)

closeBtn.MouseButton1Click:Connect(function()
    closeHub()
end)

