local function hookBoothButton(btn)

    if not (btn:IsA("TextButton") or btn:IsA("ImageButton")) then return end

    if btn:FindFirstChild("CustomPurchaseOverlay") then return end

    local id = getButtonId(btn)

    if not id then return end

    -- Disable original connections

    if getconnections then

        for _, eventName in ipairs({"MouseButton1Click", "Activated"}) do

            pcall(function()

                for _, conn in ipairs(getconnections(btn[eventName])) do

                    if conn.Function then

                        pcall(function()

                            conn:Disable()

                        end)

                    end

                end

            end)

        end

    end

    local overlay = Instance.new("TextButton")

    overlay.Name = "CustomPurchaseOverlay"

    overlay.BackgroundTransparency = 1

    overlay.Text = ""

    overlay.Size = UDim2.new(1, 0, 1, 0)

    overlay.ZIndex = (btn.ZIndex or 1) + 10 

    overlay.Parent = btn

    overlay.MouseButton1Click:Connect(function()

        local currentId = getButtonId(btn) or id

        local productInfo = getProductInfo(currentId)

        local boothUsername = getUsernameFromBoothItem(btn) or username

        

        warn("Fetched gamepass:", productInfo.Name, "| ID:", currentId)

        createPurchaseModal(productInfo.PriceInRobux, boothUsername, productInfo)

    end)

end

